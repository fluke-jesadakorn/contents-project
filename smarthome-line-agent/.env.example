# =============================================================================
# LINE Messaging API Configurations
# =============================================================================
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# Webhook listening port (default: 8646)
LINE_PORT=8646
LINE_HOST=0.0.0.0

# Public HTTPS URL of your tunnel (uncomment if sending media or assets back to LINE is needed)
# LINE_PUBLIC_URL=https://hermes.jesadakorn.com

# Gating: set true to force the bot to respond ONLY when @mentioned by name
LINE_REQUIRE_MENTION=true
# The name of the bot to look for in keyword fallbacks (optional)
LINE_BOT_NAME=HomeBot

# Allowlist: Comma-separated user/group/room IDs allowed to interact with the bot
# Leave empty to allow any user (but still restrict by LINE_REQUIRE_MENTION)
LINE_ALLOW_ALL_USERS=true
# LINE_ALLOWED_USERS=Uxxxxxxxxxxxxx...
# LINE_ALLOWED_GROUPS=Cxxxxxxxxxxxxx...

# Default channel to send notifications or cron execution reports to
# LINE_HOME_CHANNEL=Cxxxxxxxxxxxxx...

# =============================================================================
# Home Assistant Configurations
# =============================================================================
# Long-lived access token from Home Assistant Profile page
HASS_TOKEN=your_home_assistant_long_lived_access_token_here

# Home Assistant local URL (default: http://homeassistant.local:8123)
HASS_URL=http://homeassistant.local:8123

# =============================================================================
# LLM Provider & Model Configurations (Nous Hermes)
# =============================================================================
# Model selection (e.g. OpenRouter or local Ollama)
# We recommend using Nous Hermes 3 70B, GPT-4o, or Gemma 4 models
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default model to use
OPENROUTER_CHAT_MODEL=google/gemma-4-31b-it:free
# OPENROUTER_CHAT_MODEL=nousresearch/hermes-3-llama-3.1-405b:free

# Local Ollama fallback (if needed)
# OLLAMA_URL=http://localhost:11434
