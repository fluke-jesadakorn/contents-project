      "id": "extract",
      "name": "Extract text from file",
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1,
      "position": [
        1000,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "// Chunk the extracted text. ~1500 chars per chunk, 200 overlap.\nconst MAX = 1500;\nconst OVERLAP = 200;\nconst text = ($input.first().json.text || '').toString();\nif (!text.trim()) return [{ json: { empty: true, chunks: [] } }];\nconst chunks = [];\nlet i = 0, idx = 0;\nwhile (i < text.length) {\n  chunks.push({ chunk_index: idx, content: text.slice(i, i + MAX) });\n  if (i + MAX >= text.length) break;\n  i += MAX - OVERLAP;\n  idx++;\n}\nreturn [{ json: { empty: false, chunk_count: chunks.length, chunks } }];\n"
      },
      "id": "chunk",
      "name": "Chunk text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1260,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.OLLAMA_URL || 'http://host.docker.internal:11434' }}/api/embed",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"{{ $env.OLLAMA_EMBED_MODEL || 'bge-m3' }}\",\n  \"input\": {{ JSON.stringify($json.chunks.map(c => c.content)) }}\n}",
        "options": {
          "timeout": 180000
        }
      },
      "id": "embed",
      "name": "Embed all chunks (Ollama bge-m3)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1520,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "// Combine: file metadata + chunk embeddings into rows ready to insert.\nconst embedResp = $input.first().json;  // { embeddings: [[v1],[v2],...], ... }\nconst vecs = embedResp.embeddings || embedResp;  // support both /api/embed and /api/embeddings\nconst chunkInfo = $('Chunk text').first().json;\nconst download = $('Download from LINE').first().binary.data;\nconst evt = $('LINE Webhook').first().json.body.events[0];\n\nconst rows = chunkInfo.chunks.map((c, i) => ({\n  chunk_index: c.chunk_index,\n  content: c.content,\n  embedding: '[' + vecs[i].map(Number).join(',') + ']'\n}));\n\nreturn [{\n  json: {\n    file_name: download.fileName,\n    file_type: (download.fileName || '').split('.').pop().toLowerCase(),\n    size_bytes: download.fileSize,\n    line_user_id: evt.source.userId,\n    line_group_id: evt.source.groupId || null,\n    line_message_id: evt.message.id,\n    chunk_count: rows.length,\n    rows\n  }\n}];\n"
      },
      "id": "combine",
      "name": "Combine metadata + vectors",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1780,
        200
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO contracts (line_user_id, line_group_id, line_message_id, file_name, file_type, size_bytes, chunk_count, status) VALUES ('{{ $json.line_user_id }}', {{ $json.line_group_id ? \"'\" + $json.line_group_id + \"'\" : \"NULL\" }}, '{{ $json.line_message_id }}', '{{ $json.file_name.replace(/'/g, \"''\") }}', '{{ $json.file_type }}', {{ $json.size_bytes }}, {{ $json.chunk_count }}, 'ready') RETURNING id, doc_no",
        "options": {}
      },
      "id": "insert-contract",
      "name": "Insert contract row",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        2040,
        200
      ],
      "credentials": {
        "127.0.0.1": {
          "id": "regb87eec1e08a5cce3",
          "name": "PG Contracts (Mac host 55432)"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Build a multi-row INSERT for all chunks.\nconst contractId = $('Insert contract row').first().json.id;\nconst meta = $('Combine metadata + vectors').first().json;\nconst values = meta.rows.map(r =>\n  `( '${contractId}', ${r.chunk_index}, $tag$${r.content}$tag$, ${r.content.length}, '${r.embedding}'::vector )`\n).join(',\\n');\nreturn [{\n  json: {\n    sql: `INSERT INTO contract_chunks (contract_id, chunk_index, content, token_count, embedding) VALUES ${values}`\n  }\n}];\n"
      },
      "id": "build-sql",
      "name": "Build chunk INSERT SQL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2300,
        200
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ $json.sql }}",
        "options": {}
      },
